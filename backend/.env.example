# ── App ──
APP_NAME=VerifyAI
APP_ENV=development
SECRET_KEY=your-super-secret-key-change-this-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500,http://localhost:8080,http://localhost:8000,null

# ── Database ──
# SQLite (no install needed, good for dev):
DATABASE_URL=sqlite:///./verifyai.db
# PostgreSQL (for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/verifyai_db

# ── Redis Cache ──
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# ── Google Fact Check API ──
# Get from: https://developers.google.com/fact-check/tools/api
GOOGLE_FACT_CHECK_API_KEY=your-google-api-key-here

# ── NewsAPI (for URL fetching fallback) ──
# Get from: https://newsapi.org
NEWS_API_KEY=your-newsapi-key-here

# ── HuggingFace Model ──
# Uses pretrained model; change to your fine-tuned model path if available
HF_MODEL_NAME=hamzab/roberta-fake-news-classification
HF_MODEL_CACHE_DIR=./model_cache

# ── Analysis Weights (must sum to 1.0) ──
WEIGHT_NLP_MODEL=0.50
WEIGHT_FACT_CHECK=0.30
WEIGHT_SOURCE_CREDIBILITY=0.20
